\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mystyles}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta}

% 1. Define the custom color (0-255 scale)
\definecolor{brand}{RGB}{0, 122, 204}

\tikzset{
    ground hatch/.style={thin, draw=gray},
    beam/.style={line width=2pt, draw=black},
    force/.style={-Stealth, thick, brand},
    load-line/.style={thick, brand},
    support/.style={thick, draw=black},
    dimension/.style={|-|, thin, draw=gray!80},
    hinge/.style={circle, fill=white, draw=black, thick, inner sep=0pt, minimum size=4pt},
    point/.style={circle, fill=black, draw=black, thick, inner sep=0pt, minimum size=4pt}
}